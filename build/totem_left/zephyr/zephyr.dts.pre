/ {
 xiao_d: connector {
  compatible = "seeed,xiao-gpio";
  #gpio-cells = <2>;
  gpio-map-mask = <0xffffffff 0xffffffc0>;
  gpio-map-pass-thru = <0 0x3f>;
  gpio-map
   = <0 0 &gpio0 2 0>
   , <1 0 &gpio0 3 0>
   , <2 0 &gpio0 28 0>
   , <3 0 &gpio0 29 0>
   , <4 0 &gpio0 4 0>
   , <5 0 &gpio0 5 0>
   , <6 0 &gpio1 11 0>
   , <7 0 &gpio1 12 0>
   , <8 0 &gpio1 13 0>
   , <9 0 &gpio1 14 0>
   , <10 0 &gpio1 15 0>
   ;
 };
};

xiao_spi: &spi2 {};
xiao_i2c: &i2c1 {};
xiao_serial: &uart0 {};
